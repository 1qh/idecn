        { "path": "src/icon.tsx", "type": "registry:component", "target": "components/ui/tree-icon.tsx" },
        { "path": "src/cn.ts", "type": "registry:lib", "target": "lib/cn.ts" },
        { "path": "src/_generated/icon-svgs.json", "type": "registry:lib", "target": "lib/icon-svgs.json" },
        { "path": "src/_generated/manifest.json", "type": "registry:lib", "target": "lib/icon-manifest.json" }
      ]
    },
    {
      "name": "tree",
